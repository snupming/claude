{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "nuxt.config.ts",
    "app/app.vue",
    "app/pages/**/*.vue",
    "app/layouts/**/*.vue",
    "app/middleware/**/*.ts",
    "app/composables/**/*.ts",
    "app/lib/**/*.ts",
    "server/api/**/*.ts",
    "server/plugins/**/*.ts",
    "server/utils/**/*.ts",
    "vitest.config.ts",
    "**/__tests__/**/*.ts"
  ],
  "project": [
    "app/**/*.{ts,vue}",
    "server/**/*.ts"
  ],
  "ignore": [
    "app/components/ui/**"
  ],
  "ignoreDependencies": [
    "@nuxt/fonts",
    "vue-router",
    "h3",
    "eslint-plugin-vue",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser"
  ]
}
