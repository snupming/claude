{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.2",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.0",
    "@nuxt/fonts": "^0.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "happy-dom": "^20.8.9",
    "knip": "^5.30.0",
    "lint-staged": "^15.2.0",
    "shadcn-nuxt": "^2.4.3",
    "simple-git-hooks": "^2.11.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "cd frontend && pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,mjs}": [
      "eslint --fix"
    ]
  }
}
